# .env.example — documentation of environment variables

# GraphQL endpoint (Vite loads from .env.development or .env.production automatically)
VITE_API_URL=http://localhost:4000/graphql

# Base URL of backend (without /graphql) — for /auth/refresh and OAuth
VITE_API_BASE_URL=http://localhost:4000

# Site URL — for SEO meta tags
VITE_SITE_URL=https://mealvy.app

# For graphql-codegen (not VITE_ prefix)
API_URL=http://localhost:4000/graphql
